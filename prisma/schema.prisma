generator client {
    provider = "prisma-client"
    output   = "../src/generated/prisma"
}

datasource db {
    provider = "postgresql"
}

enum Role {
    USER
    ADMIN
}

enum OrgStatus {
    PENDING
    ACTIVE
    REJECTED
}

model Organization {
    id          String    @id @default(cuid())
    name        String
    location    String
    description String    @db.Text
    status      OrgStatus @default(PENDING)

    creatorId String
    creator   User   @relation(fields: [creatorId], references: [id], onDelete: Cascade)

    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    @@index([creatorId])
}

model User {
    id       String  @id @default(cuid())
    username String
    email    String  @unique
    phone    String?
    role     Role    @default(USER)

    emailVerified Boolean @default(false)
    TFAEnabled    Boolean @default(false)
    onboarded     Boolean @default(false)

    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    accounts             Account[]
    verificationTokens   VerificationToken[]
    professionalProfiles ProfessionalProfile[]
    organizations        Organization[]
}

model Account {
    id                String  @id @default(cuid())
    userId            String
    provider          String
    providerAccountID String
    password          String?

    user User @relation(fields: [userId], references: [id], onDelete: Cascade)

    @@unique([provider, providerAccountID])
}

model VerificationToken {
    id        String   @id @default(cuid())
    userId    String
    token     String   @unique
    otpHash   String
    email     String
    type      String
    expiresAt DateTime

    user User @relation(fields: [userId], references: [id], onDelete: Cascade)

    @@index([userId])
}

model ProfessionalProfile {
    id     String @id @default(cuid())
    userId String

    // The Profile Identity
    profileName String // e.g., "Full-Stack Developer"
    isDefault   Boolean @default(false)

    // The Pitch
    whyWorkHere String? @db.Text
    resumeUrl   String?

    user User @relation(fields: [userId], references: [id], onDelete: Cascade)

    experiences  Experience[]
    projects     Project[]
    achievements Achievement[]
    courses      Course[]
    educations   Education[]
    links        SocialLink[]
    skills       Skill[]

    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    @@index([userId])
}

model Experience {
    id          String              @id @default(cuid())
    profileId   String
    company     String
    title       String
    location    String?
    startDate   DateTime
    endDate     DateTime?
    isCurrent   Boolean             @default(false)
    description String              @db.Text
    profile     ProfessionalProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)
}

model Achievement {
    id          String              @id @default(cuid())
    profileId   String
    title       String
    description String              @db.Text
    location    String?
    profile     ProfessionalProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)
}

model Course {
    id             String              @id @default(cuid())
    profileId      String
    title          String
    description    String              @db.Text
    certificateUrl String?
    profile        ProfessionalProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)
}

model Project {
    id        String @id @default(cuid())
    profileId String

    name        String
    url         String?
    repoUrl     String?
    description String  @db.Text

    profile ProfessionalProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)

    @@index([profileId])
}

model Education {
    id          String              @id @default(cuid())
    profileId   String
    institution String
    degree      String
    startDate   DateTime
    endDate     DateTime?
    profile     ProfessionalProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)
}

model SocialLink {
    id        String              @id @default(cuid())
    profileId String
    platform  String // e.g., GitHub, LinkedIn
    url       String
    profile   ProfessionalProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)
}

model Skill {
    id       String                @id @default(cuid())
    name     String                @unique
    profiles ProfessionalProfile[]
}
